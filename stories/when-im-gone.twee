:: Start
(set: $hasVision to "")
(set: $disposition to "")
(set: $ashesWishes to "")
(set: $burialPlace to "")
(set: $otherDisposition to "")
(set: $serviceType to "")
(set: $serviceLocation to "")
(set: $serviceRequests to "")
(set: $flowers to "")
(set: $flowerPreference to "")
